<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Button
        android:id="@+id/buttonBackToHome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Back" />

    <TextView
        android:id="@+id/textBuildTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Build"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp" />

    <LinearLayout
        android:id="@+id/layoutSelectedParts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical" />

    <TextView
        android:id="@+id/textTotalPrice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Total: $0.00"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/textCompatibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Compatibility: Add CPU and motherboard."
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginTop="12dp" />

    <Button
        android:id="@+id/buttonClearBuild"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Clear Build"
        android:layout_marginTop="16dp" />

</LinearLayout>